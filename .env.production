# 生产环境配置 (Production)

# 应用标题
VITE_APP_TITLE=fs-bot

# 应用版本
VITE_APP_VERSION=1.0.0

# 自动更新地址
VITE_UPDATE_URL=https://example.com/auto-updates

# 接口地址
VITE_APP_API_URL=https://www.iisquare.com/api-v1

# 官网地址（注册/忘记密码跳转）
VITE_APP_WEBSITE_URL=https://www.iisquare.com

# 关闭开发者工具
VITE_DEVTOOLS=false

# 数据库加密密钥（固定混淆字符串，与用户ID组合生成加密密钥）
VITE_DB_SECRET=fSb0t#2o25_k3Y
